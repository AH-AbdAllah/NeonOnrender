# Server configuration
PORT=3000
NODE_ENV=development

# Neon PostgreSQL Relational Database (Production or Local Postgres)
DATABASE_URL=postgresql://neondb_owner:npg_HOGprawoQ5J2@ep-silent-meadow-aq357642.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=taskflow_db
DB_SSL=true

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_string_in_production_environment
JWT_EXPIRES_IN=24h

# Firestore Non-Relational Logs Database (Firebase Admin SDK)
# Optional: Can be loaded inline via JSON string or by service account file path.
# If both are empty, TaskFlow automatically uses a mock logger gracefully.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
